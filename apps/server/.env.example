PORT=4000
CORS_ORIGIN=*

# Required for POST /api/auth/firebase-exchange
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh

# Firebase Admin (required for POST /api/auth/firebase-exchange)
# NOT google-services.json — use a *service account* private key from:
# Firebase Console → Project settings → Service accounts → Generate new private key
#
# Recommended: save the downloaded JSON as firebase-service-account.json (gitignored)
# in this folder, then:
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
#
# Alternative: paste the entire service-account JSON on one line (must include
# "type", "project_id", "private_key", "client_email"):
# FIREBASE_SERVICE_ACCOUNT_JSON=
