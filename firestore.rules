rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active != false;
    }

    // Public catalog — read-only for clients; writes via Admin SDK / admin panel API.
    match /services/{serviceId} {
      allow read: if true;
      allow write: if false;
    }

    // Admin users — only readable by the signed-in admin themselves.
    match /admins/{adminId} {
      allow read: if request.auth != null && request.auth.uid == adminId;
      allow write: if false;
    }

    // Coupons — no direct client writes; server/admin SDK only.
    match /coupons/{couponId} {
      allow read: if false;
      allow write: if false;
    }

    // Cart snapshots for abandonment — server writes only.
    match /customer_carts/{customerId} {
      allow read: if false;
      allow write: if false;
    }

    // Customer profile — only the signed-in user (mobile app via API uses Admin SDK).
    match /customers/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /orders/{orderId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /activity_logs/{logId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update, delete: if false;
      }
    }
  }
}
